    "@mui/styled-engine": "^5.15.14",
    "@types/react-vertical-timeline-component": "^3.3.6",
    "axios": "^1.7.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.23.1",
    "react-typed": "^2.0.12",
    "react-vertical-timeline-component": "^3.6.0",
    "vite-plugin-svgr": "^4.2.0",
    "web-vitals": "^4.0.0"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@eslint/js": "^9.39.5",
    "@types/react": "^18.2.66",
